<%- include('./partials/header.ejs'); %>
    <div id="chat-container">
      <div id="search-container">
        <input type="text" placeholder="Search" />
      </div>
      <div id="conversation-list">
        <% data.forEach(function(conversation) { %>
          <!-- conversation creator is same to logged in user, so we need to show participant name and avatar -->
          <% if(conversation.creator.id == loggedInUser.userid) { %>
            <div class="conversation" data-conversation-id="<%= conversation._id %>" onclick="getMessages('<%= conversation._id %>', '<%= conversation.participant.name %>')">
              <% if (conversation.participant.avatar) { %>
              <img src="./uploads/avatars/<%= conversation.participant.avatar %>" alt="<%= conversation.participant.name %>" />
              <% } else { %>
                <img src="./images/nophoto.png" />
              <% } %>
              <div class="title-text"><%= conversation.participant.name %></div>
              <div class="conversation-date"><%= moment(conversation.last_updated).fromNow() %></div>
            </div>
          <% } else { %>
            <div class="conversation" data-conversation-id="<%= conversation._id %>" onclick="getMessages('<%= conversation._id %>', '<%= conversation.creator.name %>')">
              <% if (conversation.creator.avatar) { %>
              <img src="./uploads/avatars/<%= conversation.creator.avatar %>" alt="<%= conversation.creator.name %>" />
              <% } else { %>
                <img src="./images/nophoto.png" />
              <% } %>
              <div class="title-text"><%= conversation.creator.name %></div>
              <div class="conversation-date"><%= moment(conversation.last_updated).fromNow() %></div>
            </div>
          <% } %>
        <% }); %>
        
        <!-- show no conversation placeholder image for 0 conversations -->
        <% if(data && data.length === 0) { %>
          <div class="nothing"><img src="./images/no-conversation.svg"></div>
        <% } %>
      </div>

      <div class="new-message-container" onclick="openModal()">
        <a href="#">+</a>
      </div>

      <div id="chat-title" class="chat-title--no-selection">
        <span id="conversation-partner"></span>
        <button type="button" id="delete-conversation-btn" hidden aria-label="Delete conversation">
          <img src="./images/trash.png" alt="" />
        </button>
      </div>

      <!-- placeholder div if no messages are in messages area -->
      <div id="chat-message-list">
        <div class="nothing">select a conversation</div>
      </div>

      <!-- send message form -->
      <form id="chat-form" method="post" enctype="multipart/form-data">
        <label for="attachment"><img src="./images/attachment.png" alt="Add Attachment" /></label>
        <input type="file" multiple name="attachment" class="hide" id="attachment" />
        <input type="text" name="message" placeholder="Type a message" autocomplete="off" />
      </form>

    </div>
    <%- include('./partials/add-conversation-modal.ejs'); %>

    <!-- import socket io client from cdn -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/3.1.3/socket.io.min.js"></script>

    <script>

      const form = document.querySelector('#chat-form');
      const messageContainer = document.querySelector('#chat-message-list');
      const chatTitleContainer = document.querySelector('#conversation-partner');
      const chatTitleBar = document.querySelector('#chat-title');
      const deleteConversationBtn = document.querySelector('#delete-conversation-btn');
      const loggedinUserId = '<%= loggedInUser.userid %>';
      const loggedinUserName = '<%= loggedInUser.username %>';

      function isCurrentUser(senderId) {
        return String(senderId) === String(loggedinUserId);
      }

      function escapeHtml(str) {
        if (str == null || str === "") return "";
        const div = document.createElement("div");
        div.textContent = str;
        return div.innerHTML;
      }

      function buildAttachmentsHtml(attachmentList) {
        if (!attachmentList || attachmentList.length === 0) return "";
        let html = '<div class="attachments">';
        attachmentList.forEach((name) => {
          const path = "./uploads/attachments/" + name;
          html +=
            '<a href="' +
            path +
            '" target="_blank" rel="noopener noreferrer" class="attachment-link">' +
            '<img src="' +
            path +
            '" alt="Shared image" loading="lazy" class="attachment-image" /></a>';
        });
        html += "</div>";
        return html;
      }

      function buildMessageRow(opts) {
        const { text, attachment, dateTime, messageClass, sender } = opts;
        const trimmed = (text || "").trim();
        const textBlock = trimmed
          ? '<div class="message-text">' + escapeHtml(trimmed) + "</div>"
          : "";
        const attachmentsBlock = buildAttachmentsHtml(attachment);
        const timeBlock =
          '<div class="message-time">' + moment(dateTime).fromNow() + "</div>";
        const isYou = messageClass === "you-message";

        if (isYou) {
          return (
            '<div class="message-row ' +
            messageClass +
            '"><div class="message-content">' +
            textBlock +
            attachmentsBlock +
            timeBlock +
            "</div></div>"
          );
        }
        const avatarSrc = sender.avatar
          ? "./uploads/avatars/" + sender.avatar
          : "./images/nophoto.png";
        const avatar =
          '<img class="message-avatar" src="' +
          avatarSrc +
          '" alt="' +
          escapeHtml(sender.name || "") +
          '" />';
        return (
          '<div class="message-row ' +
          messageClass +
          '"><div class="message-content">' +
          avatar +
          textBlock +
          attachmentsBlock +
          timeBlock +
          "</div></div>"
        );
      }

      let participant = null; // selected conversation participant object
      let current_conversation_id; // selected conversation id

      function setDeleteConversationVisible(visible) {
        if (visible) {
          chatTitleBar.classList.remove('chat-title--no-selection');
          deleteConversationBtn.removeAttribute('hidden');
        } else {
          chatTitleBar.classList.add('chat-title--no-selection');
          deleteConversationBtn.setAttribute('hidden', '');
        }
      }

      function resetChatPane() {
        participant = null;
        current_conversation_id = undefined;
        chatTitleContainer.textContent = '';
        messageContainer.innerHTML = '<div class="nothing">select a conversation</div>';
        form.style.visibility = 'hidden';
        form.reset();
        setDeleteConversationVisible(false);
      }

      deleteConversationBtn.addEventListener('click', async function () {
        if (!current_conversation_id) return;

        const confirmed = window.confirm(
          'Delete this conversation and all its messages? This cannot be undone.'
        );
        if (!confirmed) return;

        try {
          const response = await fetch('/inbox/' + encodeURIComponent(current_conversation_id), {
            method: 'DELETE',
            headers: {
              Accept: 'application/json',
            },
          });
          const result = await response.json();

          if (!response.ok || result.errors) {
            const msg =
              result.errors?.common?.msg ||
              result.error ||
              'Could not delete conversation';
            Toastify({
              text: msg,
              duration: 2000,
            }).showToast();
            return;
          }

          const row = document.querySelector(
            '.conversation[data-conversation-id="' + current_conversation_id + '"]'
          );
          if (row) row.remove();

          resetChatPane();

          Toastify({
            text: result.message || 'Conversation deleted',
            duration: 1500,
          }).showToast();
        } catch (e) {
          Toastify({
            text: 'Could not delete conversation',
            duration: 2000,
          }).showToast();
        }
      });

      // socket initialization — join a per-user room so events are not broadcast globally
      const socket = io('<%= process.env.APP_URL %>', {
        query: { userId: loggedinUserId },
      });

      socket.on("new_conversation", (data) => {
        if (!data || !data.conversation) return;
        const c = data.conversation;
        const convId = String(c._id);
        if (document.querySelector('.conversation[data-conversation-id="' + convId + '"]')) {
          return;
        }

        const isCreator = String(c.creator.id) === String(loggedinUserId);
        const partner = isCreator ? c.participant : c.creator;
        const avatarUrl = partner.avatar
          ? "./uploads/avatars/" + partner.avatar
          : "./images/nophoto.png";
        const dateStr = moment(c.last_updated).fromNow();

        const row = document.createElement("div");
        row.className = "conversation";
        row.setAttribute("data-conversation-id", convId);
        row.onclick = function () {
          getMessages(convId, partner.name);
        };
        row.innerHTML =
          '<img src="' +
          avatarUrl +
          '" alt="' +
          escapeHtml(partner.name) +
          '" />' +
          '<div class="title-text">' +
          escapeHtml(partner.name) +
          "</div>" +
          '<div class="conversation-date">' +
          escapeHtml(dateStr) +
          "</div>";

        const list = document.querySelector("#conversation-list");
        const nothing = list.querySelector(".nothing");
        if (nothing) nothing.remove();
        list.insertBefore(row, list.firstChild);
      });

      // handle new/live incoming message from socket
      socket.on("new_message", data => {
        // only respond if current conversation is open in any client
        if(data.message.conversation_id == current_conversation_id) {
          const messageClass = isCurrentUser(data.message.sender.id) ? 'you-message' : 'other-message';
          const messageHTML = buildMessageRow({
            text: data.message.message,
            attachment: data.message.attachment,
            dateTime: data.message.date_time,
            messageClass,
            sender: data.message.sender,
          });
          document.querySelector('#chat-message-list > .message-row:first-child').insertAdjacentHTML('beforeBegin', messageHTML);
        }
      });

      // get messages of a conversation
      async function getMessages(conversation_id, current_conversation_name){

        // messages failure toast
        const messagesFailureToast = Toastify({
          text: "Error loading messages!",
          duration: 1000,
        });

        let response = await fetch(`/inbox/messages/${conversation_id}`);
        const result= await response.json();

        if(!result.errors && result.data) {
            form.style.visibility = 'visible';
            
            const {data, user, conversation_id} = result;

            participant = data.participant;
            current_conversation_id = conversation_id;
            setDeleteConversationVisible(true);

            if(data.messages) {

              let allMessages = '';

              if(data.messages.length > 0) {
                data.messages.forEach((message) => {
                  const messageClass = isCurrentUser(message.sender.id) ? 'you-message' : 'other-message';
                  const messageHTML = buildMessageRow({
                    text: message.text,
                    attachment: message.attachment,
                    dateTime: message.date_time,
                    messageClass,
                    sender: message.sender,
                  });
                  allMessages += messageHTML;
                });
                messageContainer.innerHTML = allMessages;
              } else if(data.messages.length === 0) {
                messageContainer.innerHTML = '<div class="message-row"></div>';
              }

              chatTitleContainer.textContent = current_conversation_name;
            }
        } else {
          messagesFailureToast.showToast();
        }
    }

      // message sending
      form.onsubmit = async function (event) {
        event.preventDefault();

        const sendMessageFailureToast = Toastify({
          text: "Error sending message",
          duration: 1000,
        });

        // prepare the form data
        const formData = new FormData(form);
        formData.append('receiverId', participant.id);
        formData.append('receiverName', participant.name);
        formData.append('avatar', participant.avatar || '');
        formData.append('conversationId', current_conversation_id);

        // send the request to server
        let response = await fetch("/inbox/message", {
          method: "POST",
          body: formData,
        });

        // get response
        let result = await response.json();

        if (!result.errors) {
          form.reset(); // reset the form
        } else {
          sendMessageFailureToast.showToast();
        }
      }
      
    </script>
  </body>
</html>